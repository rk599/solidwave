---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a
  href={href}
  class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:border-[#4A7C8C]/30 transition-all duration-200"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold text-[#0A2647] group-hover:text-[#4A7C8C] transition-colors">
      {title}
    </h3>
    <svg
      class="mt-0.5 h-5 w-5 flex-shrink-0 text-slate-300 group-hover:text-[#4A7C8C] group-hover:translate-x-0.5 transition-all duration-200"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </div>
  <p class="mt-2 text-slate-500 text-sm leading-relaxed">{description}</p>
</a>
