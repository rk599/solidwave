---
import type { Lang } from '@/i18n';
import { useTranslations, getFooterLinks, getServiceLinks } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const links = getFooterLinks(lang);
const services = getServiceLinks(lang);
---

<footer class="bg-[#0A2647] text-white">
  <!-- Main footer -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`/${lang}/`} aria-label="Solidwave Group AG – Home" class="inline-block mb-4">
          <img
            src="/images/solidwave-horizontal-white.svg"
            alt="Solidwave Group AG"
            class="h-7 w-auto"
            width="160"
            height="28"
          />
        </a>
        <p class="text-slate-300 text-sm leading-relaxed max-w-xs">
          {t('footer.tagline')}
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {t('footer.servicesTitle')}
        </h3>
        <ul class="space-y-2.5 text-sm">
          <!-- Health -->
          <li>
            <a href={services.health} class="text-slate-200 hover:text-white font-medium transition-colors">
              {t('nav.health')}
            </a>
            <ul class="mt-1 ml-3 space-y-1.5">
              {services.healthSubs.map(sub => (
                <li>
                  <a href={sub.href} class="text-slate-400 hover:text-slate-200 transition-colors">
                    {sub.key}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <!-- Pension -->
          <li>
            <a href={services.pension} class="text-slate-200 hover:text-white font-medium transition-colors">
              {t('nav.pension')}
            </a>
            <ul class="mt-1 ml-3 space-y-1.5">
              {services.pensionSubs.map(sub => (
                <li>
                  <a href={sub.href} class="text-slate-400 hover:text-slate-200 transition-colors">
                    {sub.key}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <!-- Property -->
          <li>
            <a href={services.property} class="text-slate-200 hover:text-white font-medium transition-colors">
              {t('nav.property')}
            </a>
            <ul class="mt-1 ml-3 space-y-1.5">
              {services.propertySubs.map(sub => (
                <li>
                  <a href={sub.href} class="text-slate-400 hover:text-slate-200 transition-colors">
                    {sub.key}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {t('footer.contactTitle')}
        </h3>
        <div class="space-y-2 text-sm text-slate-300">
          <p>
            {t('footer.emailLabel')}:{' '}
            <a href="mailto:service@solidwave.ch" class="text-slate-200 hover:text-white transition-colors">
              service@solidwave.ch
            </a>
          </p>
          <p>Zug</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#163860]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-400">
      <p>{t('footer.copyright')}</p>
      <nav class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <a href={links.legal} class="hover:text-slate-200 transition-colors">{t('footer.legal')}</a>
        <a href={links.privacy} class="hover:text-slate-200 transition-colors">{t('footer.privacy')}</a>
        <a href={links.terms} class="hover:text-slate-200 transition-colors">{t('footer.terms')}</a>
        <a href={links.vag45} class="hover:text-slate-200 transition-colors">{t('footer.vag')}</a>
      </nav>
    </div>
  </div>
</footer>
