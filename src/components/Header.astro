---
import type { Lang } from '@/i18n';
import { useTranslations, getNavLinks, getAlternateHref } from '@/i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const navLinks = getNavLinks(lang);
const altLang: Lang = lang === 'de' ? 'en' : 'de';
const altHref = getAlternateHref(new URL(currentPath, 'https://solidwave.ch'), lang);

function isActive(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-[0_1px_0_0_rgb(0_0_0/0.04)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between gap-6">

      <!-- Logo -->
      <a href={`/${lang}/`} class="flex-shrink-0 flex items-center" aria-label="Solidwave Group AG – Home">
        <img
          src="/images/solidwave-horizontal-navy.svg"
          alt="Solidwave Group AG"
          class="h-7 w-auto"
          width="160"
          height="28"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(({ href, key }) => (
          <a
            href={href}
            class={[
              'px-3 py-1.5 rounded-md text-sm font-medium transition-colors duration-150',
              isActive(href)
                ? 'text-[#0A2647] bg-slate-100'
                : 'text-slate-600 hover:text-[#0A2647] hover:bg-slate-50'
            ].join(' ')}
          >
            {t(key)}
          </a>
        ))}
      </nav>

      <!-- Right side: lang switcher + CTA -->
      <div class="flex items-center gap-3">
        <!-- Language switcher -->
        <div class="flex items-center text-sm font-medium">
          <span class={lang === 'de' ? 'text-[#0A2647] font-semibold' : 'text-slate-400'}>
            {lang === 'de' ? 'DE' : <a href={`/de/`} class="text-slate-400 hover:text-[#0A2647] transition-colors">DE</a>}
          </span>
          <span class="mx-1.5 text-slate-300">|</span>
          <span class={lang === 'en' ? 'text-[#0A2647] font-semibold' : 'text-slate-400'}>
            {lang === 'en' ? 'EN' : <a href={altHref} class="text-slate-400 hover:text-[#0A2647] transition-colors">EN</a>}
          </span>
        </div>

        <!-- CTA button (desktop) -->
        <a
          href={`/${lang}/${lang === 'de' ? 'kontakt' : 'contact'}/`}
          class="hidden sm:inline-flex items-center gap-1.5 bg-[#0A2647] hover:bg-[#0e3568] text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors duration-150"
        >
          {t('nav.contact')}
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-btn"
          type="button"
          class="lg:hidden p-2 rounded-md text-slate-600 hover:text-[#0A2647] hover:bg-slate-100 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="lg:hidden hidden border-t border-slate-100 py-3 pb-4"
    >
      <nav class="flex flex-col gap-1">
        {navLinks.map(({ href, key }) => (
          <a
            href={href}
            class={[
              'px-3 py-2.5 rounded-md text-sm font-medium transition-colors',
              isActive(href)
                ? 'text-[#0A2647] bg-slate-100'
                : 'text-slate-600 hover:text-[#0A2647] hover:bg-slate-50'
            ].join(' ')}
          >
            {t(key)}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
