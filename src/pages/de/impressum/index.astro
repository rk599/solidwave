---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { useTranslations } from '@/i18n';

const lang = 'de' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('legal.title')}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: t('breadcrumb.home'), href: '/de/' },
      { label: t('legal.breadcrumb') },
    ]} />

    <h1 class="text-3xl font-bold text-[#0A2647] mb-6">{t('legal.title')}</h1>
    
    <div class="prose-content">
      
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.companyTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.company')}</p>
        </div>
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.contactTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.contactText')}</p>
        </div>
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.registerTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.registerText')}</p>
        </div>
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.supervisoryTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.supervisoryText')}</p>
        </div>
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.disclaimerTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.disclaimerText')}</p>
        </div>
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-[#0A2647] mb-3">{t('legal.copyrightTitle')}</h2>
          <p class="text-slate-600 leading-relaxed whitespace-pre-line">{t('legal.copyrightText')}</p>
        </div>
    </div>
  </div>
</Base>
