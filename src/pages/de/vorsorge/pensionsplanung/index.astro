---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CtaBanner from '@/components/CtaBanner.astro';
const lang = 'de' as const;
---
<Base lang={lang} title="Pensionsplanung - Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[{label:'Startseite',href:'/de/'},{label:'Vorsorge',href:'/de/vorsorge/'},{label:'Pensionsplanung'}]} />
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">Pensionsplanung</h1>
      <p class="text-slate-500 text-lg mb-8">Frühzeitige Planung sichert Ihren Lebensstandard im Alter.</p>
      <p class="text-slate-600 mb-8">Die Pensionsplanung umfasst alle drei Säulen: AHV, Pensionskasse und private Vorsorge. Wir begleiten Sie auf dem Weg zu einem sorgenfreien Ruhestand.</p>
      <ul class="space-y-3">
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Vorsorgelücken-Analyse</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Pensionskassen-Einkauf</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Koordination aller drei Säulen</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Steuereffiziente Bezugsstrategie</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Planung der Frühpensionierung</li>
      </ul>
    </div>
  </div>
  <CtaBanner title="Bereit für eine Beratung?" description="Kostenlos und unverbindlich." buttonLabel="Jetzt Kontakt aufnehmen" buttonHref="/de/kontakt/" />
</Base>
