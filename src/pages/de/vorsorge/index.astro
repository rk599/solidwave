---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { useTranslations } from '@/i18n';

const lang = 'de' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('pension.heroTitle')}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: t('breadcrumb.home'), href: '/de/' },
      { label: t('pension.breadcrumb') },
    ]} />

    <div class="max-w-3xl mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">{t('pension.heroTitle')}</h1>
      <p class="text-slate-500 text-lg leading-relaxed">{t('pension.heroSub')}</p>
    </div>

    <p class="text-slate-600 leading-relaxed mb-10 max-w-3xl">{t('pension.intro')}</p>

    <div class="mb-12 max-w-3xl">
      <h2 class="text-xl font-semibold text-[#0A2647] mb-5">{t('pension.whyTitle')}</h2>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t("pension.why1")}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t("pension.why2")}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t("pension.why3")}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t("pension.why4")}</li>
      </ul>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <ServiceCard title={t('pension.p3aTitle')} description={t('pension.p3aDesc')} href="/de/vorsorge/saeule-3a/" />
      <ServiceCard title={t('pension.p3bTitle')} description={t('pension.p3bDesc')} href="/de/vorsorge/saeule-3b/" />
      <ServiceCard title={t('pension.lifeTitle')} description={t('pension.lifeDesc')} href="/de/vorsorge/lebensversicherung/" />
      <ServiceCard title={t('pension.riskTitle')} description={t('pension.riskDesc')} href="/de/vorsorge/risikoversicherung/" />
      <ServiceCard title={t('pension.kidsTitle')} description={t('pension.kidsDesc')} href="/de/vorsorge/kinderplaene/" />
        <ServiceCard title="Freizügigkeitskonten" description="Vorsorgekapital bei Stellenwechsel optimal anlegen." href="/de/vorsorge/freizuegigkeit/" />
        <ServiceCard title="Pensionsplanung" description="Frühzeitig planen für einen sorgenfreien Ruhestand." href="/de/vorsorge/pensionsplanung/" />
    </div>
  </div>

  <CtaBanner
    title={t('cta.readyTitle')}
    description={t('cta.readyDesc')}
    buttonLabel={t('cta.readyBtn')}
    buttonHref="/de/kontakt/"
  />
</Base>
