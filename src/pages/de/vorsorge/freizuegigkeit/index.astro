---
import Base from "@/layouts/Base.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CtaBanner from "@/components/CtaBanner.astro";
const lang = "de";
---
<Base lang={lang} title="Freizuegigkeitskonten - Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[{label:"Startseite",href:"/de/"},{label:"Vorsorge",href:"/de/vorsorge/"},{label:"Freizuegigkeitskonten"}]} />
    <h1 class="text-3xl font-bold text-[#0A2647] mb-4">Freizuegigkeitskonten</h1>
    <p class="text-slate-500 text-lg mb-8">Bei einem Stellenwechsel muessen Ihre Pensionskassengelder geschuetzt und optimal angelegt werden.</p>
    <ul class="space-y-3 max-w-3xl">
      <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">V</span>Vergleich von Freizuegigkeitskonten verschiedener Anbieter</li>
      <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">V</span>Beratung zur optimalen Anlagestrategie</li>
      <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">V</span>Unterstuetzung bei der Uebertragung</li>
      <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">V</span>Steueroptimierung</li>
    </ul>
  </div>
  <CtaBanner title="Beratung?" description="Kostenlos und unverbindlich." buttonLabel="Kontakt" buttonHref="/de/kontakt/" />
</Base>
