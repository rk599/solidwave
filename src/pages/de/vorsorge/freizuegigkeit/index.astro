---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CtaBanner from '@/components/CtaBanner.astro';
const lang = 'de' as const;
---
<Base lang={lang} title="Freizuegigkeitskonten - Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[{label:'Startseite',href:'/de/'},{label:'Vorsorge',href:'/de/vorsorge/'},{label:'Freizuegigkeitskonten'}]} />
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">Freizügigkeitskonten</h1>
      <p class="text-slate-500 text-lg mb-8">Vorsorgekapital bei Stellenwechsel optimal anlegen.</p>
      <p class="text-slate-600 mb-8">Wenn Sie eine Pensionskasse verlassen, müssen Ihre Freizügigkeitsleistungen innerhalb von sechs Monaten übertragen werden. Solidwave hilft Ihnen, die beste Lösung zu finden.</p>
      <ul class="space-y-3">
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Vergleich von Freizügigkeitskonten verschiedener Anbieter</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Beratung zur optimalen Anlagestrategie</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Unterstützung bei der Übertragung</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Steueroptimierung durch Aufteilung auf mehrere Konten</li>
      </ul>
    </div>
  </div>
  <CtaBanner title="Bereit für eine Beratung?" description="Kostenlos und unverbindlich." buttonLabel="Jetzt Kontakt aufnehmen" buttonHref="/de/kontakt/" />
</Base>
