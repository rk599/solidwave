---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { useTranslations } from '@/i18n';

const lang = 'de' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('property.liabilityTitle')}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: t('breadcrumb.home'), href: '/de/' },
      { label: t('property.breadcrumb'), href: '/de/sachversicherung/' },
      { label: t('property.liabilityTitle') },
    ]} />

    <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">{t('property.liabilityTitle')}</h1>
    <p class="text-slate-500 text-lg leading-relaxed mb-8">{t('property.liabilityDesc')}</p>
    <p class="text-slate-600 leading-relaxed">{t('property.intro')}</p>
  </div>

  <CtaBanner
    title={t('cta.readyTitle')}
    description={t('cta.readyDesc')}
    buttonLabel={t('cta.readyBtn')}
    buttonHref="/de/kontakt/"
  />
</Base>
