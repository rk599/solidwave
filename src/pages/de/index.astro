---
import Base from '@/layouts/Base.astro';
import { useTranslations } from '@/i18n';

const lang = 'de' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title="Solidwave Group AG – Ihr unabhängiger Versicherungsbroker in der Schweiz">

  <!-- ═══════════════════════════════════════════
       HERO — full-bleed photo, dark overlay
  ═══════════════════════════════════════════ -->
  <section class="sw-hero">
    <div class="sw-hero__bg">
      <img
        src="https://images.unsplash.com/photo-1527095341820-8a04e9d43c8b?w=1920&q=85&auto=format&fit=crop"
        alt="Schweizer Alpen"
        class="sw-hero__img"
        loading="eager"
      />
      <div class="sw-hero__overlay"></div>
    </div>

    <div class="sw-hero__content">
      <div class="sw-hero__badge">
        <span class="sw-dot"></span>
        FINMA-registriert · Zug, Schweiz
      </div>

      <h1 class="sw-hero__title">
        Versicherungen,<br/>
        <em>die zu Ihrem</em><br/>
        Leben passen.
      </h1>

      <p class="sw-hero__sub">
        Unabhängige Beratung von echten Experten –<br class="sw-hide-mobile"/>
        kostenlos, persönlich und ohne Interessenkonflikte.
      </p>

      <div class="sw-hero__actions">
        <a href="/de/kontakt/" class="sw-btn sw-btn--primary">
          Kostenlose Beratung
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="#services" class="sw-btn sw-btn--ghost">Unsere Leistungen</a>
      </div>

      <div class="sw-hero__trust">
        <div class="sw-trust-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
          100% unabhängig
        </div>
        <div class="sw-trust-sep"></div>
        <div class="sw-trust-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 8.25H9m6 3H9m3 6-3-3h1.5a3 3 0 1 0 0-6M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          Beratung kostenlos
        </div>
        <div class="sw-trust-sep"></div>
        <div class="sw-trust-item">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
          50+ Versicherungspartner
        </div>
      </div>
    </div>

    <!-- scroll indicator -->
    <div class="sw-hero__scroll" aria-hidden="true">
      <div class="sw-scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       STATS — animated counters
  ═══════════════════════════════════════════ -->
  <section class="sw-stats reveal">
    <div class="sw-container">
      <div class="sw-stats__grid">
        <div class="sw-stat">
          <span class="sw-stat__num" data-target="100" data-suffix="%">0%</span>
          <span class="sw-stat__label">Unabhängig von Versicherern</span>
        </div>
        <div class="sw-stat sw-stat--accent">
          <span class="sw-stat__num" data-target="50" data-suffix="+">0+</span>
          <span class="sw-stat__label">Versicherungspartner</span>
        </div>
        <div class="sw-stat">
          <span class="sw-stat__num" data-target="800" data-prefix="CHF " data-suffix="/J.">CHF 0/J.</span>
          <span class="sw-stat__label">Mögliche Ersparnis pro Jahr</span>
        </div>
        <div class="sw-stat">
          <span class="sw-stat__num" data-target="0" data-prefix="CHF ">CHF 0</span>
          <span class="sw-stat__label">Kosten für Sie</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES — asymmetric photo + cards
  ═══════════════════════════════════════════ -->
  <section id="services" class="sw-services">
    <div class="sw-container">
      <div class="sw-section-label reveal">Unsere Dienstleistungen</div>
      <h2 class="sw-section-title reveal">Drei Bereiche.<br/><span class="sw-muted">Ein Ziel.</span></h2>

      <div class="sw-services__grid">

        <!-- Photo card -->
        <div class="sw-services__photo reveal">
          <img
            src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=800&q=85&auto=format&fit=crop&crop=top"
            alt="Professionelle Beratung"
            class="sw-photo-fill"
          />
          <div class="sw-services__photo-badge">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
            Persönlich &amp; unabhängig
          </div>
        </div>

        <!-- Service cards -->
        <div class="sw-services__cards">
          <a href="/de/krankenkasse/" class="sw-service-card reveal">
            <div class="sw-service-card__icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            </div>
            <div class="sw-service-card__body">
              <h3>Krankenkasse</h3>
              <p>Grundversicherung & Zusatzversicherung – wir finden die günstigste Lösung für Sie.</p>
              <ul>
                <li>Grundversicherung</li>
                <li>Zusatzversicherung</li>
                <li>Prämienvergleich</li>
              </ul>
            </div>
            <svg class="sw-service-card__arrow" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>

          <a href="/de/vorsorge/" class="sw-service-card sw-service-card--dark reveal">
            <div class="sw-service-card__icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>
            </div>
            <div class="sw-service-card__body">
              <h3>Vorsorge</h3>
              <p>Säule 3a, 3b und Lebensversicherung – wir sichern Ihre finanzielle Zukunft.</p>
              <ul>
                <li>Säule 3a & 3b</li>
                <li>Lebensversicherung</li>
                <li>Kinderpläne</li>
              </ul>
            </div>
            <svg class="sw-service-card__arrow" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>

          <a href="/de/sachversicherung/" class="sw-service-card reveal">
            <div class="sw-service-card__icon">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
            </div>
            <div class="sw-service-card__body">
              <h3>Sachversicherung</h3>
              <p>Auto, Hausrat, Haftpflicht – rundum geschützt im Alltag.</p>
              <ul>
                <li>Autoversicherung</li>
                <li>Hausrat & Haftpflicht</li>
                <li>Rechtsschutz</li>
              </ul>
            </div>
            <svg class="sw-service-card__arrow" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS — horizontal timeline
  ═══════════════════════════════════════════ -->
  <section class="sw-how">
    <div class="sw-container">
      <div class="sw-section-label reveal">So funktioniert es</div>
      <h2 class="sw-section-title reveal">In 3 Schritten zu Ihrer <span class="sw-muted">optimalen Lösung</span></h2>

      <div class="sw-steps">
        <div class="sw-step reveal">
          <div class="sw-step__num">01</div>
          <div class="sw-step__icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V20.25a.75.75 0 0 0 1.28.53l3.58-3.58A48.22 48.22 0 0 0 11.25 17c2.08 0 4.14-.133 6.16-.39"/></svg>
          </div>
          <h3>Beratungsgespräch</h3>
          <p>Wir analysieren Ihre Situation und klären Ihre Bedürfnisse – kostenlos und unverbindlich.</p>
        </div>

        <div class="sw-step__connector" aria-hidden="true">
          <svg width="40" height="16" fill="none" viewBox="0 0 40 16"><path d="M0 8h32M26 2l8 6-8 6" stroke="#4A7C8C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="sw-step reveal" style="animation-delay:0.15s">
          <div class="sw-step__num">02</div>
          <div class="sw-step__icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>
          </div>
          <h3>Vergleich & Empfehlung</h3>
          <p>Wir vergleichen 50+ Anbieter und präsentieren Ihnen die beste und günstigste Lösung.</p>
        </div>

        <div class="sw-step__connector" aria-hidden="true">
          <svg width="40" height="16" fill="none" viewBox="0 0 40 16"><path d="M0 8h32M26 2l8 6-8 6" stroke="#4A7C8C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <div class="sw-step reveal" style="animation-delay:0.3s">
          <div class="sw-step__num">03</div>
          <div class="sw-step__icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
          </div>
          <h3>Umsetzung & Betreuung</h3>
          <p>Wir kümmern uns um den Wechsel und bleiben Ihr persönlicher Ansprechpartner.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY US — full-bleed split with photo
  ═══════════════════════════════════════════ -->
  <section class="sw-why">
    <div class="sw-why__photo">
      <img
        src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&q=85&auto=format&fit=crop"
        alt="Beratungsgespräch Solidwave"
        class="sw-photo-fill"
      />
    </div>
    <div class="sw-why__content">
      <div class="sw-section-label sw-section-label--light reveal">Warum Solidwave?</div>
      <h2 class="sw-why__title reveal">Ihr Vorteil:<br/><em>Wir arbeiten nur für Sie.</em></h2>
      <p class="sw-why__lead reveal">Keine Bindung an Versicherungsgesellschaften. Keine versteckten Interessen. Nur das Beste für Sie.</p>

      <div class="sw-why__points">
        {[
          { icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z', title: 'Unabhängig', desc: 'An keine Versicherungsgesellschaft gebunden – wir beraten ausschliesslich in Ihrem Interesse.' },
          { icon: 'M15 8.25H9m6 3H9m3 6-3-3h1.5a3 3 0 1 0 0-6M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z', title: 'Kostenfrei', desc: 'Unsere Beratung ist für Sie 100% kostenlos. Wir werden von den Versicherern vergütet.' },
          { icon: 'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z', title: 'Persönlich', desc: 'Kein Callcenter, keine Warteschlangen – immer ein fester Ansprechpartner für Sie.' },
          { icon: 'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5', title: 'Transparent', desc: 'Offene Kommunikation über Prämien, Leistungen und Vergütung gemäss VAG Art. 45.' },
        ].map((item, i) => (
          <div class="sw-why__point reveal" style={`animation-delay:${i * 0.1}s`}>
            <div class="sw-why__point-icon">
              <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
              </svg>
            </div>
            <div>
              <strong>{item.title}</strong>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <a href="/de/kontakt/" class="sw-btn sw-btn--teal reveal" style="animation-delay:0.4s">
        Jetzt beraten lassen
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       QUOTE / TESTIMONIAL
  ═══════════════════════════════════════════ -->
  <section class="sw-quote reveal">
    <div class="sw-container sw-container--narrow">
      <svg class="sw-quote__mark" width="48" height="36" viewBox="0 0 48 36" fill="none">
        <path d="M0 36V22C0 9 7.5 2 22.5 0L24 4C17 5.5 13 10 13 16H21V36H0ZM27 36V22C27 9 34.5 2 49.5 0L51 4C44 5.5 40 10 40 16H48V36H27Z" fill="#4A7C8C" fill-opacity="0.25"/>
      </svg>
      <blockquote class="sw-quote__text">
        "Versicherungen sind komplex. Unser Ziel ist es, diese Komplexität für unsere Kunden zu beseitigen – und sicherzustellen, dass Sie immer optimal geschützt sind, ohne dafür zu viel zu bezahlen."
      </blockquote>
      <div class="sw-quote__author">
        <div class="sw-quote__avatar">MM</div>
        <div>
          <strong>Solidwave Group AG</strong>
          <span>Zug, Schweiz · FINMA-registriert</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA — full-bleed photo
  ═══════════════════════════════════════════ -->
  <section class="sw-cta">
    <div class="sw-cta__bg">
      <img
        src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80&auto=format&fit=crop"
        alt="Zug, Schweiz"
        class="sw-photo-fill"
        loading="lazy"
      />
      <div class="sw-cta__overlay"></div>
    </div>
    <div class="sw-cta__content reveal">
      <p class="sw-cta__sup">Kostenlos & unverbindlich</p>
      <h2 class="sw-cta__title">Bereit für eine unabhängige Beratung?</h2>
      <p class="sw-cta__desc">Kontaktieren Sie uns – wir antworten innerhalb von 24 Stunden.</p>
      <div class="sw-cta__actions">
        <a href="/de/kontakt/" class="sw-btn sw-btn--white">
          Jetzt Kontakt aufnehmen
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="mailto:service@solidwave.ch" class="sw-btn sw-btn--ghost-white">
          service@solidwave.ch
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
/* ── Reset / base ─────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Layout helpers ──────────────────────────────────── */
.sw-container        { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
.sw-container--narrow{ max-width: 780px; margin: 0 auto; padding: 0 1.5rem; }
.sw-photo-fill       { width: 100%; height: 100%; object-fit: cover; display: block; }
.sw-hide-mobile      { display: none; }
@media(min-width:768px){ .sw-hide-mobile { display: inline; } }

/* ── Scroll reveal ───────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}
.reveal.visible {
  opacity: 1;
  transform: none;
}

/* ── Dot ─────────────────────────────────────────────── */
.sw-dot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #4A7C8C;
  animation: pulse 2s infinite;
}
