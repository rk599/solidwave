--- 
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ContactForm from '@/components/ContactForm';
import { useTranslations } from '@/i18n';

const lang = 'de' as const;
const t = useTranslations(lang);

const labels = {
  name: t('contact.name'),
  namePlaceholder: t('contact.namePlaceholder'),
  email: t('contact.email'),
  emailPlaceholder: t('contact.emailPlaceholder'),
  phone: t('contact.phone'),
  phonePlaceholder: t('contact.phonePlaceholder'),
  topic: t('contact.topic'),
  topicDefault: t('contact.topicDefault'),
  topic1: t('contact.topic1'),
  topic2: t('contact.topic2'),
  topic3: t('contact.topic3'),
  topic4: t('contact.topic4'),
  message: t('contact.message'),
  messagePlaceholder: t('contact.messagePlaceholder'),
  submit: t('contact.submit'),
  sending: t('contact.sending'),
  successTitle: t('contact.successTitle'),
  successDesc: t('contact.successDesc'),
  errorTitle: t('contact.errorTitle'),
  errorDesc: t('contact.errorDesc'),
};
---

<Base lang={lang} title={t('contact.heroTitle')}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: t('breadcrumb.home'), href: '/de/' },
      { label: t('contact.breadcrumb') },
    ]} />

    <div class="mb-10 max-w-xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-3">{t('contact.heroTitle')}</h1>
      <p class="text-slate-500 text-lg">{t('contact.heroSub')}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <div class="lg:col-span-3">
        <ContactForm client:load lang={lang} labels={labels} />
      </div>

      <div class="lg:col-span-2 space-y-8">
        <div>
          <h3 class="text-base font-semibold text-[#0A2647] mb-4">{t('contact.otherTitle')}</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-[#0A2647]/5 flex-shrink-0">
                <svg class="h-4 w-4 text-[#4A7C8C]" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-700">{t('contact.emailLabel')}</p>
                <a href="mailto:service@solidwave.ch" class="text-sm text-[#4A7C8C] hover:underline">service@solidwave.ch</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-[#0A2647]/5 flex-shrink-0">
                <svg class="h-4 w-4 text-[#4A7C8C]" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-700">Telefon</p>
                <a href="tel:+41615311070" class="text-sm text-[#4A7C8C] hover:underline">+41 61 531 10 70</a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-[#0A2647]/5 flex-shrink-0">
                <svg class="h-4 w-4 text-[#4A7C8C]" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-700">{t('contact.addressLabel')}</p>
                <p class="text-sm text-slate-500">Solidwave Group AG<br/>Lauriedhofweg 1<br/>6300 Zug<br/>Schweiz</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-lg bg-[#0A2647]/5 flex-shrink-0">
                <svg class="h-4 w-4 text-[#4A7C8C]" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-700">{t('contact.hoursLabel')}</p>
                <p class="text-sm text-slate-500">{t('contact.hours')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
