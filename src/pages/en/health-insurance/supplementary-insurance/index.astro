---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { useTranslations } from '@/i18n';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title={t('suppInsurance.heroTitle')}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: t('breadcrumb.home'), href: '/en/' },
      { label: t('health.breadcrumb'), href: '/en/health-insurance/' },
      { label: t('suppInsurance.breadcrumb') },
    ]} />

    <div class="max-w-3xl mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">{t('suppInsurance.heroTitle')}</h1>
      <p class="text-slate-500 text-lg leading-relaxed">{t('suppInsurance.heroSub')}</p>
    </div>

    <p class="text-slate-600 leading-relaxed mb-10 max-w-3xl">{t('suppInsurance.intro')}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10 max-w-3xl">
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-base font-semibold text-[#0A2647] mb-2">{t('suppInsurance.feat1Title')}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{t('suppInsurance.feat1Desc')}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-base font-semibold text-[#0A2647] mb-2">{t('suppInsurance.feat2Title')}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{t('suppInsurance.feat2Desc')}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-base font-semibold text-[#0A2647] mb-2">{t('suppInsurance.feat3Title')}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{t('suppInsurance.feat3Desc')}</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-base font-semibold text-[#0A2647] mb-2">{t('suppInsurance.feat4Title')}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{t('suppInsurance.feat4Desc')}</p>
        </div>
    </div>

    <div class="mb-8 max-w-3xl">
      <h2 class="text-xl font-semibold text-[#0A2647] mb-5">{t('suppInsurance.offerTitle')}</h2>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t('suppInsurance.offer1')}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t('suppInsurance.offer2')}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t('suppInsurance.offer3')}</li>
        <li class="flex items-start gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{t('suppInsurance.offer4')}</li>
      </ul>
    </div>
    
    <div class="mt-12 max-w-3xl">
      <h2 class="text-xl font-semibold text-[#0A2647] mb-5">{t('basicInsurance.relatedTitle')}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <ServiceCard title={t('health.basicTitle')} description={t('health.basicDesc')} href="/en/health-insurance/basic-insurance/" />
      </div>
    </div>
  </div>

  <CtaBanner
    title={t('cta.readyTitle')}
    description={t('cta.readyDesc')}
    buttonLabel={t('cta.readyBtn')}
    buttonHref="/en/contact/"
  />
</Base>
