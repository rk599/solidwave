---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import CtaBanner from '@/components/CtaBanner.astro';

const lang = 'en' as const;
---

<Base lang={lang} title="Vested Benefits Accounts – Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/en/' },
      { label: 'Pension Planning', href: '/en/pension-planning/' },
      { label: 'Vested Benefits' },
    ]} />

    <div class="max-w-3xl mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">Vested benefits accounts – safeguard your pension capital</h1>
      <p class="text-slate-500 text-lg leading-relaxed">When changing jobs or taking a career break, your pension fund assets need to be protected and optimally invested.</p>
    </div>

    <p class="text-slate-600 leading-relaxed mb-10 max-w-3xl">When you leave a pension fund – whether due to a job change, unemployment, or a sabbatical – your vested benefits must be transferred to a vested benefits account or policy within six months. Choosing the right provider and investment strategy has a significant long-term impact on your pension capital. Solidwave helps you find the best solution.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10 max-w-3xl">
      {[
        { title: 'Transfer obligation within 6 months', desc: 'After leaving a pension fund, your vested benefits must be transferred within the deadline. Otherwise, the funds are transferred to the BVG Substitute Occupational Benefit Institution.' },
        { title: 'Bank account or insurance policy', desc: 'Bank accounts offer flexibility and typically lower costs. Insurance policies combine savings with risk coverage for disability or death. We show you the pros and cons of each.' },
        { title: 'Tax advantages', desc: 'Assets remain exempt from income and wealth tax. By strategically splitting funds across two accounts, you can further optimize your tax burden upon withdrawal.' },
        { title: 'Investment options and returns', desc: 'Various investment strategies are available – from conservative to equity-based. With a long investment horizon, an active strategy can significantly grow your capital.' },
      ].map(item => (
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-base font-semibold text-[#0A2647] mb-2">{item.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="mb-10 max-w-3xl">
      <h2 class="text-xl font-semibold text-[#0A2647] mb-5">What We Offer</h2>
      <ul class="space-y-2.5">
        {[
          'Comparison of vested benefits accounts and policies from various providers',
          'Advice on the optimal investment strategy based on your time horizon',
          'Support with transferring your vested benefits',
          'Tax optimization through splitting funds across multiple accounts',
        ].map(item => (
          <li class="flex items-start gap-2 text-slate-600">
            <span class="text-[#4A7C8C] font-bold mt-0.5">✓</span>{item}
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-10 max-w-3xl">
      <h2 class="text-xl font-semibold text-[#0A2647] mb-5">Related Topics</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <ServiceCard title="Pillar 3a – save taxes" description="Restricted pension is one of the most effective tax optimization instruments in Switzerland." href="/en/pension-planning/pillar-3a/" />
        <ServiceCard title="Pension Consulting" description="Early and comprehensive retirement planning ensures you can maintain your standard of living." href="/en/pension-planning/pension-consulting/" />
      </div>
    </div>
  </div>

  <CtaBanner
    title="Ready for independent advice?"
    description="Contact us for a free and non-binding initial consultation. Together, we will find the optimal solution for your insurance needs."
    buttonLabel="Get in Touch"
    buttonHref="/en/contact/"
  />
</Base>
