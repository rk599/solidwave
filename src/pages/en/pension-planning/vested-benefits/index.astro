---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CtaBanner from '@/components/CtaBanner.astro';
const lang = 'en' as const;
---
<Base lang={lang} title="Vested Benefits - Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[{label:'Home',href:'/en/'},{label:'Pension Planning',href:'/en/pension-planning/'},{label:'Vested Benefits'}]} />
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">Vested benefits accounts</h1>
      <p class="text-slate-500 text-lg mb-8">Safeguard your pension capital during job changes or career breaks.</p>
      <p class="text-slate-600 mb-8">When you leave a pension fund, your vested benefits must be transferred within six months. Solidwave helps you find the best solution.</p>
      <ul class="space-y-3">
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Comparison of vested benefits accounts from various providers</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Advice on optimal investment strategy</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Support with transferring your vested benefits</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Tax optimization through splitting across multiple accounts</li>
      </ul>
    </div>
  </div>
  <CtaBanner title="Ready for advice?" description="Free and non-binding consultation." buttonLabel="Get in Touch" buttonHref="/en/contact/" />
</Base>
