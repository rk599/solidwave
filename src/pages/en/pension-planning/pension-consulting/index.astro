---
import Base from '@/layouts/Base.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import CtaBanner from '@/components/CtaBanner.astro';
const lang = 'en' as const;
---
<Base lang={lang} title="Pension Consulting - Solidwave Group AG">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-20">
    <Breadcrumb crumbs={[{label:'Home',href:'/en/'},{label:'Pension Planning',href:'/en/pension-planning/'},{label:'Pension Consulting'}]} />
    <div class="max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-bold text-[#0A2647] mb-4">Pension consulting</h1>
      <p class="text-slate-500 text-lg mb-8">Plan your retirement right with comprehensive guidance.</p>
      <p class="text-slate-600 mb-8">Retirement planning covers all three pillars of the Swiss pension system. We help identify gaps early and optimize your withdrawal strategy.</p>
      <ul class="space-y-3">
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Pension gap analysis</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Pension fund buy-in advice</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Coordination of all three pillars</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Tax-efficient withdrawal strategy</li>
        <li class="flex gap-2 text-slate-600"><span class="text-[#4A7C8C] font-bold">&#10003;</span>Early retirement planning</li>
      </ul>
    </div>
  </div>
  <CtaBanner title="Ready for advice?" description="Free and non-binding consultation." buttonLabel="Get in Touch" buttonHref="/en/contact/" />
</Base>
